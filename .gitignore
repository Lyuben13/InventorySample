# .gitignore за C# .NET проект с поддръжка за шрифтове

# Build резултати
bin/
obj/
out/

# User specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Visual Studio
.vs/
*.vcxproj.filters
*.vcxproj.user

# NuGet
*.nupkg
**/packages/*
!**/packages/repositories.config
*.nuget.props
*.nuget.targets

# Rider
.idea/
*.sln.iml

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Logs
*.log

# Database
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.temp
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# НЕ изключваме шрифтове - искаме да ги качим в GitHub!
# *.ttf
# *.otf
# *.woff
# *.woff2

# Изключваме само системни шрифтове
C:/Windows/Fonts/*
/System/Library/Fonts/*
/usr/share/fonts/*
/usr/local/share/fonts/*

# Configuration files with sensitive data
appsettings*.json
!appsettings.json
config.json
secrets.json

# Documentation build
docs/_build/
docs/site/

# Publish folders
publish/
Publish/

# Node.js (ако се използва)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml
.dockerignore
